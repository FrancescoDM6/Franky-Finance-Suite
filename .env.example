# Phinan Finance Suite Configuration

# Database
PHINAN_DATABASE__PATH=~/.phinan/phinan.duckdb

# Google Gemini LLM (Primary - recommended)
# Get your API key from: https://aistudio.google.com/app/apikey
PHINAN_GEMINI_API_KEY=
PHINAN_GEMINI_MODEL=gemini-2.0-flash-exp
PHINAN_GEMINI_TIMEOUT=60

# Ollama LLM (Fallback - local inference)
# Used automatically if Gemini API key is not set
PHINAN_OLLAMA_BASE_URL=http://localhost:11434
PHINAN_OLLAMA_MODEL=llama3.2:latest
PHINAN_OLLAMA_TIMEOUT=120

# AI Services (disable by default for faster startup)
PHINAN_AI_SERVICES_SENTIMENT_MODEL=yiyanghkust/finbert-tone
PHINAN_AI_SERVICES_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PHINAN_AI_SERVICES_ENABLE_SENTIMENT=false
PHINAN_AI_SERVICES_ENABLE_VOLATILITY=false
PHINAN_AI_SERVICES_ENABLE_EMBEDDINGS=false

# Market Data
PHINAN_MARKET_DATA_PROVIDER=yfinance
PHINAN_MARKET_DATA_CACHE_TTL_MINUTES=5

# Application
PHINAN_DEBUG=true

# Resource Management (for Oracle Free Tier / constrained environments)
# ResourceMonitor will disable local AI features when memory exceeds this threshold
MAX_MEMORY_THRESHOLD_PERCENT=85
