# Phinan Finance Suite Configuration
# Defaults shown match phinan/config/settings.py. Override only what you need.

# Database
PHINAN_DATABASE__PATH=./data/phinan.duckdb

# Google Gemini LLM (Primary - recommended)
# Get your API key from: https://aistudio.google.com/app/apikey
PHINAN_GEMINI_API_KEY=
PHINAN_GEMINI_MODEL=gemini-3.1-flash-lite

# Ollama LLM (Fallback - local inference)
# Used automatically if Gemini API key is not set
PHINAN_OLLAMA_BASE_URL=http://localhost:11434
PHINAN_OLLAMA_MODEL=llama3.2:latest
PHINAN_OLLAMA_TIMEOUT=120

# AI Services (disabled by default for faster startup)
PHINAN_AI_SERVICES_SENTIMENT_MODEL=ProsusAI/finbert
PHINAN_AI_SERVICES_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PHINAN_AI_SERVICES_ENABLE_SENTIMENT=false
PHINAN_AI_SERVICES_ENABLE_VOLATILITY=false
PHINAN_AI_SERVICES_ENABLE_EMBEDDINGS=false

# Market Data
PHINAN_MARKET_DATA_PROVIDER=openbb
PHINAN_MARKET_DATA_OPENBB_PROVIDER=yfinance
PHINAN_MARKET_DATA_CACHE_TTL_MINUTES=5
PHINAN_MARKET_DATA_RATE_LIMIT_DELAY=0.5

# Application
PHINAN_DEBUG=true

# Resource Management (for Oracle Free Tier / constrained environments)
# ResourceMonitor will disable local AI features when memory exceeds this threshold
MAX_MEMORY_THRESHOLD_PERCENT=85

# Structured note valuation (Notes module)
# PHINAN_STRUCTURED_PRODUCTS_RISK_FREE_RATE=0.045
# PHINAN_STRUCTURED_PRODUCTS_DEFAULT_CREDIT_SPREAD=0.01
# PHINAN_STRUCTURED_PRODUCTS_DEFAULT_CORRELATION=0.6
# PHINAN_STRUCTURED_PRODUCTS_DEFAULT_N_PATHS=10000
# PHINAN_STRUCTURED_PRODUCTS_MAX_PATHS=50000
# PHINAN_STRUCTURED_PRODUCTS_VOL_LOOKBACK_PERIOD=1y
