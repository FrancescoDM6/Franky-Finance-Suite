# Phinan Finance Suite Configuration

# Database
PHINAN_DATABASE_PATH=~/.phinan/phinan.duckdb

# Ollama LLM
PHINAN_OLLAMA_BASE_URL=http://localhost:11434
PHINAN_OLLAMA_MODEL=llama3.2:latest
PHINAN_OLLAMA_TIMEOUT=120

# AI Services (disable by default for faster startup)
PHINAN_AI_SERVICES_SENTIMENT_MODEL=yiyanghkust/finbert-tone
PHINAN_AI_SERVICES_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PHINAN_AI_SERVICES_ENABLE_SENTIMENT=false
PHINAN_AI_SERVICES_ENABLE_VOLATILITY=false
PHINAN_AI_SERVICES_ENABLE_EMBEDDINGS=false

# Market Data
PHINAN_MARKET_DATA_PROVIDER=yfinance
PHINAN_MARKET_DATA_CACHE_TTL_MINUTES=5

# Application
PHINAN_DEBUG=true
