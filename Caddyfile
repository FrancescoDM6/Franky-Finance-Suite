:{$PORT}

encode gzip

# Backend routes - proxy to Uvicorn
@backend_routes path /_event/* /ping /_upload /_upload/*
handle @backend_routes {
    reverse_proxy localhost:8000
}

# Health check endpoints - proxy to FastAPI
@health_routes path /health /health/*
handle @health_routes {
    reverse_proxy localhost:8000
}

# Static files - serve pre-built frontend
root * /srv
route {
    try_files {path} {path}/ /404.html
    file_server
}
