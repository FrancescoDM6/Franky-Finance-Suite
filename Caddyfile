:{$PORT}

log {
	output stdout
    level INFO
}

encode gzip

route {
	# Backend routes - specific paths first
	handle /_event/* {
		reverse_proxy 127.0.0.1:8000
	}
	handle /ping {
		reverse_proxy 127.0.0.1:8000
	}
	handle /_upload/* {
		reverse_proxy 127.0.0.1:8000
	}

	# Health check endpoints
	handle /health/* {
		reverse_proxy 127.0.0.1:8000
	}

	# API routes
	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	# Fallback: Static files
	handle {
		root * /srv
		try_files {path} {path}/ /index.html
		file_server
	}
}
