:{$PORT}

encode gzip

# API and dynamic routes - explicit handle blocks for clarity
@dynamic {
    path /_event/* /ping /_upload/* /health/* /api/*
}

handle @dynamic {
    reverse_proxy 127.0.0.1:8000
}

# Static files (catch-all, must be last)
# Serves from /srv, falls back to index.html for SPA routing
handle {
    root * /srv
    try_files {path} /index.html
    file_server
}
