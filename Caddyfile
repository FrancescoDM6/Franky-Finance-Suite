:{$PORT}

# Debug logging
log {
    output stdout
    level DEBUG
}

# Set root directory for all static files
root * /srv

# Compression
encode gzip

# Backend routes - proxy to Uvicorn
@backend {
    path /_event/* /ping /_upload/* /health/* /api/*
}
reverse_proxy @backend 127.0.0.1:8000

# SPA fallback and static file serving
try_files {path} /index.html
file_server
