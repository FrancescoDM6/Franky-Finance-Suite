:{$PORT}

log {
    output stdout
    level DEBUG
}

# Serve static files first
file_server {
    root /srv
}

# Then handle backend routes
@backend {
    path /_event/* /ping /_upload/* /health/* /api/*
}
reverse_proxy @backend 127.0.0.1:8000

# SPA fallback - rewrite unknown paths to index.html
@notfound {
    not file
    not path /_event/* /ping /_upload/* /health/* /api/*
}
rewrite @notfound /index.html
