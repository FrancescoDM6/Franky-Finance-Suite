{$DOMAIN::80}

log {
    output stdout
    level INFO
    format console
}

respond /healthz "OK" 200

root * /srv
encode gzip

# Backend routes MUST be handled before SPA fallback
@backend {
    path /_event /_event/* /ping /_upload /_upload/* /health/* /api/* /_ws/*
}
handle @backend {
    reverse_proxy 127.0.0.1:8000 {
        flush_interval -1
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Static files + SPA fallback for everything else
handle {
    try_files {path} /index.html
    file_server
}
